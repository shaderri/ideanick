{
  "name": "@ideanick/webapp",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "test": "dotenv -e .env.test -e .env jest",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prettify": "prettier --log-level warn --cache --write \"{src/**/*,*}.{ts,tsx,js,json,yml,scss}\"",
    "types": "tsc --noEmit --project ./tsconfig.app.json && tsc --noEmit --project ./tsconfig.node.json",
    "lint": "eslint --cache --cache-location ./node_modules/.eslintcache --ext .ts,.tsx ./src",
    "stylelint": "stylelint --cache --cache-location ./node_modules/.stylelintcache \"src/**/*.scss\"",
    "stylecheck": "sass --update -q ./src:./node_modules/.cache/.stylecheckcache"
  },
  "dependencies": {
    "@ideanick/backend": "workspace:*",
    "@ideanick/shared": "workspace:*",
    "@nanostores/react": "^1.1.0",
    "@sentry/react": "^10.53.1",
    "@tanstack/react-query": "^4.18.0",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "formik": "^2.4.6",
    "formik-validator-zod": "^2.2.0",
    "include-media": "^2.0.0",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "mixpanel-browser": "^2.80.0",
    "nanostores": "^1.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.5.0",
    "react-image-gallery": "^2.1.2",
    "react-infinite-scroller": "^1.2.6",
    "react-router-dom": "^7.6.0",
    "reset-css": "^5.0.2",
    "sass": "^1.89.2",
    "superjson": "^1.13.3",
    "usehooks-ts": "^3.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.3.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.17",
    "@types/mixpanel-browser": "^2.66.0",
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-image-gallery": "^1.2.4",
    "@types/react-infinite-scroller": "^1.2.5",
    "@vitejs/plugin-legacy": "^4.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.16",
    "dotenv-cli": "11.0.0",
    "rollup-plugin-visualizer": "^5.9.2",
    "stylelint": "^16.21.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "tsc-alias": "^1.8.17",
    "vite": "^6.0.5",
    "vite-plugin-svgr": "^4.5.0"
  }
}
